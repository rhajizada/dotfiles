{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "duckduckgo": {
      "type": "local",
      "command": ["docker", "run", "-i", "--rm", "mcp/duckduckgo"],
      "enabled": true,
    },
    "fetch": {
      "type": "local",
      "command": ["docker", "run", "-i", "--rm", "mcp/fetch"],
      "enabled": true,
    },
    "next-devtools-mcp": {
      "type": "local",
      "command": ["docker", "run", "-i", "--rm", "mcp/next-devtools-mcp"],
      "enabled": true,
    },
    "openapi": {
      "type": "local",
      "command": ["docker", "run", "-i", "--rm", "-e", "MODE", "mcp/openapi"],
      "enabled": true,
      "environment": {
        "MODE": "Stdio",
      },
    },
    "sequentialthinking": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "-e",
        "MODE",
        "mcp/sequentialthinking",
      ],
      "enabled": true,
      "environment": {
        "MODE": "Stdio",
      },
    },
    "kaneo": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "--rm",
        "-i",
        "-e",
        "KANEO_API_URL",
        "-e",
        "KANEO_API_TOKEN",
        "kaneo-mcp-server:latest",
      ],
      "enabled": true,
      "environment": {
        "KANEO_API_URL": "{env:KANEO_API_URL}",
        "KANEO_API_TOKEN": "{env:KANEO_API_TOKEN}",
      },
    },
  },
  "provider": {
    "llamero": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Llamero",
      "options": {
        "baseURL": "{env:LLAMERO_API_BASE}",
        "apiKey": "{env:LLAMERO_API_KEY}",
      },
      "models": {
        "llama3.2:3b": {
          "name": "Llama3.2 3b",
          "tool_call": true,
          "limit": {
            "context": 131072,
            "output": 4096,
          },
        },
        "qwen3.5:0.8b": {
          "name": "Qwen3.5 0.8b",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 262144,
            "output": 4096,
          },
        },
        "qwen3.5:2b": {
          "name": "Qwen3.5 2b",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 262144,
            "output": 4096,
          },
        },
        "qwen3.5:4b": {
          "name": "Qwen3.5 4b",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 212992,
            "output": 4096,
          },
        },
        "qwen3:8b": {
          "name": "Qwen3 8b",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 40960,
            "output": 4096,
          },
        },
        "qwen3.5:9b": {
          "name": "Qwen3.5 9b",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 131072,
            "output": 4096,
          },
        },
        "OmniCoder:9b": {
          "name": "OmniCoder 9b",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 131072,
            "output": 4096,
          },
        },
        "ministral-3:8b": {
          "name": "Ministral 3 8b",
          "tool_call": true,
          "limit": {
            "context": 57344,
            "output": 4096,
          },
        },
        "nemotron-3-nano:4b": {
          "name": "Nemotron-3 Nano 4b",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 262144,
            "output": 4096,
          },
        },
      },
    },
    "LM Studio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1",
      },
      "models": {
        "zai-org/glm-4.6v-flash": {
          "name": "GLM 4.6v Flash 9b",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 32768,
            "output": 4096,
          },
        },
      },
    },
  },
  "plugin": ["opencode-handoff", "@mohak34/opencode-notifier@latest"],
}
